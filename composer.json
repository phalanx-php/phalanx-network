{
    "name": "phalanx-php/argos",
    "description": "Network discovery, probing, and device management for Phalanx",
    "license": "MIT",
    "type": "library",
    "keywords": ["network", "discovery", "mdns", "ssdp", "wol", "ping", "scan", "async", "openswoole"],
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@phalanx-php.com"
        }
    ],
    "homepage": "https://github.com/phalanx-php/phalanx-argos",
    "require": {
        "php": "^8.4",
        "ext-openswoole": "*",
        "phalanx-php/aegis": "^0.6",
        "mlocati/ip-lib": "^1.22"
    },
    "suggest": {},
    "autoload": {
        "psr-4": {
            "Phalanx\\Argos\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\Argos\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.2.x-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
